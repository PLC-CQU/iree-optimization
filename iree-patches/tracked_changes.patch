+    return success();
+  }
+
   if (isa<linalg::GenericOp>(linalgOp) && linalgOp.isAllParallelLoops()) {
     return blockDynamicDimensionsOfAllTensorOperandsAndResults(
         rewriter, dynamicDimAnalysis, linalgOp);
