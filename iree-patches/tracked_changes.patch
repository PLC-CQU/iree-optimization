+/// Try to replace dynamic linalg loop bounds with proven constant upper bounds
+/// from the surrounding IR. This keeps the operation dynamically typed, but
+/// gives GPU schedule selection a finite problem size for cases where the
+/// dynamic dimensions are known to be bounded by tensor dims/assumptions.
+static bool inferDynamicLoopUpperBounds(linalg::LinalgOp linalgOp,
+                                        SmallVectorImpl<int64_t> &bounds) {
+  SmallVector<AffineMap> maps = linalgOp.getIndexingMapsArray();
+  OperandRange operands = linalgOp->getOperands();
+  if (maps.size() != operands.size()) {
+    return false;
+  }
+
+  bool inferredAnyBound = false;
+  for (auto [loopDim, bound] : llvm::enumerate(bounds)) {
+    if (ShapedType::isStatic(bound)) {
+      continue;
+    }
+    for (auto [operand, map] : llvm::zip_equal(operands, maps)) {
+      auto shapedType = dyn_cast<ShapedType>(operand.getType());
+      if (!shapedType) {
+        continue;
+      }
+      for (auto [operandDim, expr] : llvm::enumerate(map.getResults())) {
+        auto dimExpr = dyn_cast<AffineDimExpr>(expr);
+        if (!dimExpr || dimExpr.getPosition() != loopDim ||
+            operandDim >= shapedType.getRank()) {
+          continue;
+        }
+        FailureOr<DimBoundSize> maybeUpperBound =
+            computeDimUpperBound(operand, operandDim,
+                                 /*vscaleRange=*/std::nullopt);
+        if (succeeded(maybeUpperBound) && !maybeUpperBound->scalable &&
+            maybeUpperBound->baseSize > 0) {
+          bound = maybeUpperBound->baseSize;
+          inferredAnyBound = true;
+          break;
+        }
+      }
+      if (ShapedType::isStatic(bound)) {
+        break;
+      }
+    }
+  }
+  return inferredAnyBound;
+}
