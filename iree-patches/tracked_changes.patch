 /// Block dynamic dimensions in operands of `LinalgOp`.
+static bool isDynamicAttentionContextContraction(linalg::LinalgOp linalgOp) {
+  if (!linalg::isaContractionOpInterface(linalgOp)) {
+    return false;
+  }
+
+  FailureOr<linalg::ContractionDimensions> maybeContractionDims =
+      linalg::inferContractionDims(linalgOp);
+  if (failed(maybeContractionDims) || maybeContractionDims->m.empty() ||
+      maybeContractionDims->n.size() != 1 ||
+      maybeContractionDims->k.size() != 1) {
+    return false;
+  }
+
+  SmallVector<int64_t> bounds = linalgOp.getStaticLoopRanges();
+  int64_t nBound = bounds[maybeContractionDims->n.front()];
+  int64_t kBound = bounds[maybeContractionDims->k.front()];
+  if (nBound != 128 || !ShapedType::isDynamic(kBound)) {
+    return false;
+  }
+
+  if (!llvm::all_of(maybeContractionDims->m, [&](unsigned dim) {
+        return ShapedType::isDynamic(bounds[dim]);
+      })) {
+    return false;
+  }
+
+  if (linalgOp.getDpsInputs().size() < 2 || linalgOp.getDpsInits().empty()) {
+    return false;
+  }
+  return getElementTypeOrSelf(linalgOp.getDpsInputOperand(0)->get()).isF16() &&
+         getElementTypeOrSelf(linalgOp.getDpsInputOperand(1)->get()).isF16() &&
+         getElementTypeOrSelf(linalgOp.getDpsInitOperand(0)->get()).isF32();
+}
